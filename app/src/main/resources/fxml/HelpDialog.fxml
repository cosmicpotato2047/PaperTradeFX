<!-- File: resources/fxml/HelpDialog.fxml -->
<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.papertradefx.controller.HelpController">
  <center>
    <TextArea fx:id="helpTextArea" editable="false" wrapText="true" prefWidth="400" prefHeight="300"/>
  </center>
  <bottom>
    <HBox alignment="CENTER_RIGHT" padding="10">
      <Button fx:id="okButton" text="OK"/>
    </HBox>
  </bottom>
</BorderPane>
